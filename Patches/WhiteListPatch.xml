  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Milira Race</li>
    </mods>
    <match Class="PatchOperationSequence">
      <success>Always</success>
      <operations>
        <li Class="PatchOperationAdd">
          <xpath>
            /Defs/AlienRace.ThingDef_AlienRace[defName="Milira_Race"]/alienRace/raceRestriction/whiteApparelList</xpath>
          <value>
            <!-- <li>XiaoTiEquipment</li> -->
            <li>XiaoTi_Backpack_ShieldPack</li>
          </value>
        </li>
      </operations>
    </match>
  </Operation>

  <Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Odyssey">
    <xpath>/Defs/RitualOutcomeEffectDef[defName="GravshipLaunch"]/comps</xpath>
    <value>
      <li Class="RitualOutcomeComp_GravshipFacilities">
        <label>CP-23"峦障"</label>
        <facilityQualityOffsets>
          <li>
            <key>CellofPowerguard</key>
            <value>0.25</value>
          </li>
        </facilityQualityOffsets>
      </li>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd" MayRequire="Ludeon.RimWorld.Odyssey">
    <xpath>
      /Defs/ThingDef[defName="GravEngine"]/comps/li[@Class="CompProperties_AffectedByFacilities"]/linkableFacilities</xpath>
    <value>
      <li>CellofPowerguard</li>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="HydroponicsBasin"]/building/sowTag</xpath>
    <value>
      <sowTag>Ground</sowTag>
    </value>
  </Operation>

