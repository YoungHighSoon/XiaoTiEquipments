<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <Operation  Class="PatchOperationFindMod">
        <mods><li>Kiiro_Race</li></mods>
        <match Class="PatchOperationSequence">
        <success>Always</success>
        <operations>
            <li Class="PatchOperationAdd">
            <xpath>/Defs/AlienRace.ThingDef_AlienRace[defName="Kiiro_Race"]/alienRace/raceRestriction/whiteApparelList</xpath>
            <value>
                <!-- <li>XiaoTiEquipment</li> -->
                <li>XiaoTi_Backpack_ShieldPack</li>
            </value>
            </li>
        </operations>
        </match>
    </Operation>

    <Operation  Class="PatchOperationFindMod">
        <mods><li>Milira Race</li></mods>
        <match Class="PatchOperationSequence">
        <success>Always</success>
        <operations>
            <li Class="PatchOperationAdd">
            <xpath>/Defs/AlienRace.ThingDef_AlienRace[defName="Milira_Race"]/alienRace/raceRestriction/whiteApparelList</xpath>
            <value>
                <!-- <li>XiaoTiEquipment</li> -->
                <li>XiaoTi_Backpack_ShieldPack</li>
            </value>
            </li>
        </operations>
        </match>
