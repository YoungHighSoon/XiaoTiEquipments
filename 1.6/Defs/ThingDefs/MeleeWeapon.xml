<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef Name="XiaoTi_MeleeWeapon_Sharp" ParentName="BaseMeleeWeapon" Abstract="True">
    <weaponClasses>
      <li>MeleePiercer</li>
    </weaponClasses>
    <recipeMaker>
      <defaultIngredientFilter>
        <categories>
          <li>Root</li>
        </categories>
        <disallowedThingDefs>
          <li>Silver</li>
          <li>Gold</li>
          <li>WoodLog</li>
        </disallowedThingDefs>
      </defaultIngredientFilter>
    </recipeMaker>
    <statBases>
      <DeteriorationRate>0</DeteriorationRate>
    </statBases>
    <useHitPoints>False</useHitPoints>
  </ThingDef>

  <ThingDef Name="XiaoTi_MeleeWeapon_Blunt" ParentName="BaseMeleeWeapon" Abstract="True">
    <weaponClasses>
      <li>MeleeBlunt</li>
    </weaponClasses>
    <recipeMaker>
      <defaultIngredientFilter>
        <categories>
          <li>Root</li>
        </categories>
        <disallowedThingDefs>
          <li>Silver</li>
          <li>Gold</li>
        </disallowedThingDefs>
      </defaultIngredientFilter>
    </recipeMaker>
  </ThingDef>

  <ToolCapacityDef>
    <defName>Demolish_Cut</defName>
    <label>破墙斩</label>
  </ToolCapacityDef>

  <ManeuverDef Name="Demolish_Cut">
    <defName>Demolish_Cut</defName>
    <requiredCapacity>Demolish_Cut</requiredCapacity>
    <verb>
      <verbClass>Verb_MeleeAttackDamage</verbClass>
      <meleeDamageDef>Demolish_Cut</meleeDamageDef>
      <ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
    </verb>
    <logEntryDef>MeleeAttack</logEntryDef>
    <combatLogRulesHit>Maneuver_Smash_MeleeHit</combatLogRulesHit>
    <combatLogRulesDeflect>Maneuver_Smash_MeleeDeflect</combatLogRulesDeflect>
    <combatLogRulesMiss>Maneuver_Smash_MeleeMiss</combatLogRulesMiss>
    <combatLogRulesDodge>Maneuver_Smash_MeleeDodge</combatLogRulesDodge>
  </ManeuverDef>

  <ThingDef Name="XiaoTi_MeleeWeapon_Sharp_Quality" Abstract="True" ParentName="XiaoTi_MeleeWeapon_Sharp">
    <comps>
      <li>
        <compClass>CompQuality</compClass>
      </li>
      <li Class="CompProperties_Art">
        <nameMaker>NamerArtWeaponMelee</nameMaker>
        <descriptionMaker>ArtDescription_WeaponMelee</descriptionMaker>
        <minQualityForArtistic>Excellent</minQualityForArtistic>
      </li>
    </comps>
  </ThingDef>

    <ThingDef ParentName="XiaoTi_MeleeWeapon_Sharp_Quality">
