    <weaponTags>
      <!-- <li>MedievalMeleeDecent</li> -->
      <li>Bladelink</li>
    </weaponTags>
    <statBases>
      <WorkToMake>12000</WorkToMake>
      <!-- <MaxHitPoints>1000</MaxHitPoints> -->
      <Mass>0.60</Mass>
      <Flammability>0</Flammability>
      <Beauty>8000</Beauty>
      <MeditationFocusStrength>0.72</MeditationFocusStrength>
