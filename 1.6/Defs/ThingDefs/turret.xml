  <ThingDef ParentName="Guard_AutocannonTurret">
    <defName>Archar_Medium_GuardTurret</defName>
    <label>AMGT - “长臂管辖”</label>
    <description>一种重型自动炮塔。它的大口径炮弹能够在可观的攻击范围内对目标造成快速且毁灭性的打击。</description>
    <uiIconPath>Things/Building/Security/TurretAutocannon_MenuIcon</uiIconPath>
    <stuffCategories>
      <!-- <li>GodIngot_Metallic</li> -->
      <li>Metallic</li>
    </stuffCategories>
    <costStuffCount>1</costStuffCount>
    <comps>
      <li Class="XiaoTiEquipment.CompProperties_BuildingSelfRepair">
        <repairIntervalTicks>60</repairIntervalTicks>
        <UsePercentRepair>true</UsePercentRepair>
        <repairPercent>0.3</repairPercent>
        <repairOnlyWhenDamaged>true</repairOnlyWhenDamaged>
        <showrepairinfo>false</showrepairinfo>
      </li>
    </comps>
    <building>
      <turretGunDef>Gun_Archar_Turret</turretGunDef>
      <turretBurstCooldownTime>3</turretBurstCooldownTime>
    </building>
    <!-- <researchPrerequisites>
      <li>HeavyTurrets</li>
    </researchPrerequisites> -->
  </ThingDef>

