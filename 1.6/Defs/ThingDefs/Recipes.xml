<Defs>
	<RecipeDef>
		<defName>AdministerGreenPin</defName>
		<label>注射强效针剂</label>
		<description>对强效针剂进行注射。</description>
		<workerClass>Recipe_AdministerUsableItem</workerClass>
		<jobString>正在注射强效针剂。</jobString>
		<targetsBodyPart>false</targetsBodyPart>
		<anesthetize>false</anesthetize>
		<workAmount>240</workAmount>
		<dontShowIfAnyIngredientMissing>true</dontShowIfAnyIngredientMissing>
		<surgeryOutcomeEffect IsNull="True" />
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Repair_GreenPin</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Repair_GreenPin</li>
			</thingDefs>
		</fixedIngredientFilter>
	</RecipeDef>

	<ThingDef Name="XiaoTi_BenchBase" ParentName="BuildingBase" Abstract="True">
		<canOverlapZones>false</canOverlapZones>
		<minifiedDef>MinifiedThing</minifiedDef>
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<thingCategories>
			<li>BuildingsProduction</li>
		</thingCategories>
		<statBases>
			<Mass>5</Mass>
		</statBases>
		<interactionCellIcon>DiningChair</interactionCellIcon>
		<comps>
			<li Class="CompProperties_ReportWorkSpeed">
				<workSpeedStat>WorkTableWorkSpeedFactor</workSpeedStat>
			</li>
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ReportWorkSpeedPenalties</li>
		</placeWorkers>
		<building>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
		</building>
	</ThingDef>

	<ThingDef ParentName="XiaoTi_BenchBase">
		<defName>XiaoTi_workstationA</defName>
		<label>虚空制造工作台</label>
		<description>一种支持你左脚踩右脚上天的设备</description>
		<thingClass>Building_WorkTable</thingClass>
		<graphicData>
			<texPath>Things/Building/Table/VoidTable/VoidTable</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>(1,1)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<castEdgeShadows>true</castEdgeShadows>
		<staticSunShadowHeight>0.20</staticSunShadowHeight>

		<costList>
			<Steel>75</Steel>
			<!-- <Plasteel>25</Plasteel>
      <ComponentIndustrial>5</ComponentIndustrial> -->
		</costList>

		<altitudeLayer>Building</altitudeLayer>
		<fillPercent>0.75</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<WorkToBuild>2000</WorkToBuild>
			<MaxHitPoints>2400</MaxHitPoints>
			<Flammability>0</Flammability>
			<WorkTableWorkSpeedFactor>1.5</WorkTableWorkSpeedFactor>
		</statBases>
		<size>(1,1)</size>
		<designationCategory>Production</designationCategory>
		<passability>PassThroughOnly</passability>
		<pathCost>13</pathCost>
		<defaultPlacingRot>South</defaultPlacingRot>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,1)</interactionCellOffset>
		<interactionCellIcon>Stool</interactionCellIcon>
		<surfaceType>Item</surfaceType>
		<inspectorTabs>
			<li>ITab_Bills</li>
		</inspectorTabs>
		<building>
			<spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
		</building>
		<comps>
			<li Class="XiaoTiEquipment.CompProperties_BuildingSelfRepair">
				<repairIntervalTicks>600</repairIntervalTicks>
				<UsePercentRepair>true</UsePercentRepair>
				<repairPercent>1</repairPercent>
				<repairOnlyWhenDamaged>true</repairOnlyWhenDamaged>
				<showrepairinfo>false</showrepairinfo>
			</li>
			<li Class="CompProperties_Flickable" />
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>ToolCabinet</li>
				</linkableFacilities>
			</li>
			<li Class="CompProperties_Breakdownable" />
		</comps>
		<placeWorkers>
			<li>PlaceWorker_ShowFacilitiesConnections</li>
		</placeWorkers>
		<researchPrerequisites>
			<li>Electricity</li>
		</researchPrerequisites>
		<recipes>
			<li>ToMake_GodGolen_IngotFromSteel</li>
			<li>Steel_ToMake_Plasteel</li>
			<li>ToMake_SteelFromGodGolen_Ingot</li>
			<li>Steel_ToMake_ArcheanSeed</li>
			<li>Steel_ToMake_Neutroamine</li>
			<li>Steel_ToMake_Gold</li>
			<li>Steel_ToMake_PsychicAmplifier</li>
			<li MayRequire="Ludeon.RimWorld.Biotech">Steel_ToMake_Mechlink</li>
			<li>Steel_ToMake_Uranium</li>
			<li>Void_ToMake_MedicineUltratech</li>
			<li>Steel_ToMake_GoldGodsilk</li>
			<li MayRequire="miho.fortifiedoutremer">Steel_ToMake_Miho_ExoticMatter</li>
		</recipes>
	</ThingDef>


