<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingCategoryDef>
    <defName>XiaoTiApparel</defName>
    <label>HD2装备</label>
    <parent>ApparelUtility</parent>
  </ThingCategoryDef>

  <ThingCategoryDef>
    <defName>XiaoTiApparel_Weaopn</defName>
    <label>武器</label>
    <parent>XiaoTiApparel</parent>
  </ThingCategoryDef>

  <ThingCategoryDef>
    <defName>XiaoTiApparel_equip</defName>
    <label>配备</label>
    <parent>XiaoTiApparel</parent>
  </ThingCategoryDef>
    <!-- RH2 Backpack Base -->

  <ThingDef Name="XiaoTi_BackpackBase" ParentName="ApparelNoQualityBase" Abstract="True">
    <recipeMaker>
      <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
      <workSkill>Crafting</workSkill>
      <effectWorking>Tailor</effectWorking>
      <soundWorking>Recipe_Tailor</soundWorking>
      <recipeUsers>
        <li>ElectricTailoringBench</li>
        <li>HandTailoringBench</li>
				<li>XiaoTi_workstationA</li>
      </recipeUsers>
      <unfinishedThingDef>UnfinishedApparel</unfinishedThingDef>
      <!-- <defaultIngredientFilter>
        <categories>
          <li>Root</li>
        </categories>
        <disallowedThingDefs>
          <li>Gold</li>
          <li>Silver</li>
          <li>Plasteel</li>
          <li>Jade</li>
          <li>Uranium</li>
          <li MayRequire="Ludeon.RimWorld.Anomaly">Bioferrite</li>
          <li MayRequire="Ludeon.RimWorld.Odyssey">Obsidian</li>
        </disallowedThingDefs>
      </defaultIngredientFilter> -->
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
    </recipeMaker>

    <thingClass>Apparel</thingClass>
    <category>Item</category>
    <drawerType>MapMeshOnly</drawerType>
    <selectable>True</selectable>
    <pathCost>14</pathCost>
    <useHitPoints>True</useHitPoints>
	  <techLevel>Industrial</techLevel> 
    <tradeability>All</tradeability>
    <resourceReadoutPriority>Middle</resourceReadoutPriority>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <onGroundRandomRotateAngle>35</onGroundRandomRotateAngle>
    </graphicData>
    <drawGUIOverlay>true</drawGUIOverlay>
    <statBases>
      <!-- <MaxHitPoints>100</MaxHitPoints>
      <Flammability>1.0</Flammability> -->
      <Beauty>9</Beauty>
    </statBases>
    <altitudeLayer>Item</altitudeLayer>
    <alwaysHaulable>True</alwaysHaulable>
    <tickerType>Never</tickerType>
    <burnableByRecipe>false</burnableByRecipe>
    <smeltable>true</smeltable>
    <rotatable>false</rotatable>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li>
        <compClass>CompColorable</compClass>
      </li>
    </comps>
    <apparel>
      <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
	    <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <wornGraphicData>
        <renderUtilityAsPack>true</renderUtilityAsPack>	
      </wornGraphicData>
      <careIfWornByCorpse>false</careIfWornByCorpse>
      <careIfDamaged>false</careIfDamaged>
      <wearPerDay>0</wearPerDay>
      <bodyPartGroups>
        <li>Shoulders</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <!-- <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags> -->
	    <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
    </apparel>
    <!-- <tradeTags>
      <li>XiaoTi_FBackpack</li>
      <li>Clothing</li>
    </tradeTags> -->
    <thingCategories>
      <li>XiaoTiApparel_equip</li>
    </thingCategories>
  </ThingDef>

  <ThingDef ParentName="XiaoTi_BackpackBase">
    <defName>XiaoTi_Backpack_ShieldPack</defName>
    <label>防护罩-护盾生成包</label>
    <description>SEAF配备的防护罩生成包，以球状护盾包裹佩戴者，抵挡高速射弹。</description>
    <graphicData>
      <texPath>Things/Apparel/Backpack/Shield_Pack/HD2_ShieldBackPack_north</texPath>
      <graphicClass>Graphic_Single</graphicClass> 	  
	  <shaderType>CutoutComplex</shaderType>
	  <drawSize>0.9</drawSize>
    </graphicData>
    <recipeMaker>
      <recipeUsers>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
				<li>XiaoTi_workstationA</li>
      </recipeUsers>
    </recipeMaker>
    <apparel>
      <wornGraphicPath>Things/Apparel/Backpack/Shield_Pack/HD2_ShieldBackPack</wornGraphicPath>
      <wornGraphicData>
        <east>
          <offset>(-0.30,-0.05)</offset> 
          <thin><offset>(0.05,0)</offset></thin>
          <hulk><offset>(-0.1,0)</offset></hulk>
          <fat><offset>(-0.15,0)</offset></fat>
		  <female><offset>(0.02,0)</offset></female>
        </east>
        <west>
          <offset>(0.30,-0.10)</offset>
          <thin><offset>(-0.05,0)</offset></thin>
          <hulk><offset>(0.1,0)</offset></hulk>
          <fat><offset>(0.15,0)</offset></fat>
		  <female><offset>(-0.02,0)</offset></female>		  
        </west>
        <north>
          <offset>(0,-0.1)</offset> 
          <thin><offset>(0,0)</offset></thin>
          <hulk><offset>(0,-0.05)</offset></hulk>
          <fat><offset>(0,-0.05)</offset></fat>
        </north>		
        <male>  <scale>(0.90,0.90)</scale></male>
        <female><scale>(0.90,0.90)</scale></female>
        <thin>  <scale>(0.70,0.70)</scale></thin>
        <hulk>  <scale>(1.0,1.0)</scale></hulk>
        <fat>   <scale>(1.0,1.0)</scale></fat>
      </wornGraphicData>
      <tags>
		<!-- <li>RH2_Helldivers_ShieldPack</li>	
		<li>RH2_Helldivers_Backpack</li>	
		<li>RH2_Backpack_HD2</li>	 -->
		    <li>XiaoTiEquipment</li>
        <li>ApparelTag_Suit_sheildbackpack</li>
      </tags>
	  <useWornGraphicMask>true</useWornGraphicMask>
      <bodyPartGroups>
        <li>FullHead</li>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
        <li>Hands</li>
        <li>Waist</li>
        <li>Feet</li>
      </bodyPartGroups>
    </apparel>
	<tickerType>Normal</tickerType>
  <useHitPoints>false</useHitPoints>
    <statBases>
      <!-- <MaxHitPoints>1000</MaxHitPoints> -->
      <Flammability>0</Flammability>
      <!-- <MaxHitPoints /> -->
      <WorkToMake>12000</WorkToMake>
      <Mass>0.05</Mass>
      <DeteriorationRate>0</DeteriorationRate>
	    <Insulation_Cold>96</Insulation_Cold>
	    <Insulation_Heat>48</Insulation_Heat>
      <EquipDelay>0.20</EquipDelay>
	    <EnergyShieldRechargeRate>3</EnergyShieldRechargeRate>
      <EnergyShieldEnergyMax>10</EnergyShieldEnergyMax>
      <ArmorRating_Sharp>1.3</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.9</ArmorRating_Blunt>
      <ArmorRating_Heat>2</ArmorRating_Heat>
			<!-- <StuffEffectMultiplierArmor>0.6</StuffEffectMultiplierArmor> -->
    </statBases>
    <equippedStatOffsets>
      <XiaoTi_ExtraCaravanCarryCapacity>300</XiaoTi_ExtraCaravanCarryCapacity>
      <VacuumResistance>1</VacuumResistance>
      <CarryingCapacity>300</CarryingCapacity>
      <IncomingDamageFactor>-0.8</IncomingDamageFactor>
      <RK_Stat_ShieldBlockChance MayRequire="Solaris.RatkinRaceMod">8</RK_Stat_ShieldBlockChance>
      <MechBandwidth MayRequire="Ludeon.RimWorld.Biotech">36</MechBandwidth>
      <CaravanBonusSpeedFactor>30</CaravanBonusSpeedFactor>
      <ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
      <RM_MalevolentQiCapacity MayRequire="fxz.moelotlzombie.update">3500</RM_MalevolentQiCapacity>
	  </equippedStatOffsets>
		<comps>
      <li Class="XiaoTiEquipment.CompProperties_RangedShieldBelt">
        <bubbleMatPath>Things/Apparel/Backpack/Shield_Pack/YellowShield</bubbleMatPath>
        <shader>Transparent</shader>
        <startingTicksToReset>120</startingTicksToReset>
        <minDrawSize>2.0</minDrawSize>
        <maxDrawSize>2.0</maxDrawSize>
        <energyLossPerDamage>0.01</energyLossPerDamage>
        <energyOnReset>2.0</energyOnReset>
        <blocksRangedWeapons>false</blocksRangedWeapons>
        <spinRate>0.10</spinRate>
        <flickerRate>0.005</flickerRate>
      </li>
      <li Class="XiaoTiEquipment.CompProperties_ApparelAddHediff">
        <hediffsToAdd>
            <li>Cross_The_Bleach</li>
            <li MayRequire="fxz.moelotlzombie.update">XiaoTiEquipment_MalevolentLimiter</li>
        </hediffsToAdd>
        <useHediffInitialSeverity>false</useHediffInitialSeverity>
        <hediffSeverity>0.3</hediffSeverity>
      </li>
      <li Class="Axolotl.CompProperties_Apparel_LotlQiShield" MayRequire="fxz.moelotlzombie.update">
        <LotlQiShieldCount>150</LotlQiShieldCount>
        <LotlQiShieldReSetOffset>0.6</LotlQiShieldReSetOffset>
      </li>
      <li Class="XiaoTiEquipment.CompProperties_WearableTurretMount">
        <mountedGunDefs>
          <li>P4PeaceKeeper_turret</li>
          <li>Hand_Gun_turret_Auto</li>
          <li MayRequire="fxz.moelotlzombie.update">Hand_Gun_turret_malevolent</li>
        </mountedGunDefs>
        <burstWarmupTime>1</burstWarmupTime>
        <burstCooldownTime>-1</burstCooldownTime>
        <!-- <autoAttack>true</autoAttack> -->
        <attackUndrafted>true</attackUndrafted>
      </li>
		</comps>
  <costList>
    <Plasteel>10</Plasteel>
    <P4PeaceKeeper>1</P4PeaceKeeper>
  </costList>
  <modExtensions>
    <li Class="XiaoTiEquipment.ModExtension_ExtraBlockedDamages">
      <extraDamageDefNames>
        <li>AL_Damage_PsyChic</li>
        <li>AL_Damage_Void</li>
      </extraDamageDefNames>
    </li>
  </modExtensions>
  </ThingDef>

</Defs>