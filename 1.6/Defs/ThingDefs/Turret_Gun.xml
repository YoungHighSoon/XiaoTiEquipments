  </ThingDef>
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>P4PeaceKeeper_turret</defName>
    <label>维和者-自动</label>
    <description>
      P-4“维和者”是一款双动式左轮手枪，此随身武器攻击力强大，相当可靠。虽然弹容量只有六发，但其厚重的枪身和高口径弹药使其成为近距离对抗装甲目标的理想之选，受到了那些注重力大砖飞的野蛮火力的老兵的青睐。</description>
    <graphicData>
      <texPath>Things/Weapons/Senator</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.70</drawSize>
    </graphicData>
    <soundInteract>RNPickup_R4Senator</soundInteract>
    <statBases>
      <WorkToMake>1000</WorkToMake>
      <RangedWeapon_DamageMultiplier>1</RangedWeapon_DamageMultiplier>
      <Mass>0.06</Mass>
      <RangedWeapon_Cooldown>3</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>XiaoTiEquipment.Verb_ShootWearableTurret</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>125_rifle_Bullet_sidearm</defaultProjectile>
        <warmupTime>1</warmupTime>
        <range>30</range>
        <ticksBetweenBurstShots>36</ticksBetweenBurstShots>
        <burstShotCount>6</burstShotCount>
        <soundCast>P4PeaceKeeper_Shot</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
      </li>
    </verbs>
  </ThingDef>
