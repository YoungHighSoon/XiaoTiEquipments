<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Gun_Double_Mechine_Turret</defName>
    <label>典礼官</label>
    <description>高速穿甲武器，射速极快</description>
    <graphicData>
      <texPath>Things/Building/Security/Turret_D</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <RangedWeapon_Cooldown>0.01</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>0.2</Mass>
      <Flammability>0</Flammability>
      <AccuracyLong>0.7</AccuracyLong>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>125_rifle_Bullet_sidearm</defaultProjectile>
        <warmupTime>0</warmupTime>
        <range>299</range>
        <ticksBetweenBurstShots>2</ticksBetweenBurstShots>
        <burstShotCount>120</burstShotCount>
        <soundCast>MG43_Shoot</soundCast>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>2</muzzleFlashScale>
        <hasStandardCommand>true</hasStandardCommand>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
          <canTargetPawns>true</canTargetPawns>
          <canTargetLocations>true</canTargetLocations>
          <canTargetBuildings>true</canTargetBuildings>
        </targetParams>
      </li>
    </verbs>
  </ThingDef>
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Light_Guard_Turret_Gun</defName>
    <label>轻型防卫机枪</label>
    <description>安装在炮塔上的简易自动机枪。</description>
    <graphicData>
      <texPath>Things/Building/Security/TurretMini_Top</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <AccuracyTouch>0.9</AccuracyTouch>
      <AccuracyShort>0.8</AccuracyShort>
      <AccuracyMedium>0.8</AccuracyMedium>
      <AccuracyLong>0.7</AccuracyLong>
      <RangedWeapon_Cooldown>1.5</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>1</Mass>
      <Flammability>0</Flammability>
      <RangedWeapon_DamageMultiplier>0.75</RangedWeapon_DamageMultiplier>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>762x51mm_Bullet_LMG</defaultProjectile>
        <warmupTime>0</warmupTime>
        <range>64</range>
        <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
        <burstShotCount>30</burstShotCount>
        <soundCast>M105Stalwart_Shot</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
        <hasStandardCommand>true</hasStandardCommand>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
          <canTargetPawns>true</canTargetPawns>
          <canTargetLocations>true</canTargetLocations>
          <canTargetBuildings>true</canTargetBuildings>
        </targetParams>
        <!-- <consumeFuelPerShot>1</consumeFuelPerShot> -->
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Gun_Archar_Turret</defName>
    <label>长臂管辖</label>
    <description>大口径远距离精准武器，子弹附有溅射伤害</description>
    <graphicData>
      <texPath>Things/Building/Security/TurretAutocannon_Top</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <RangedWeapon_Cooldown>1.25</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>0.2</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>Bullet_40MMHEAT_Autocannon</defaultProjectile>
        <forcedMissRadius>6</forcedMissRadius>
        <!-- <defaultProjectile>Bullet_40MMHEAT_Autocannon</defaultProjectile> -->
        <warmupTime>0</warmupTime>
        <!-- <minRange>2</minRange> -->
        <range>299</range>
        <ticksBetweenBurstShots>14</ticksBetweenBurstShots>
        <burstShotCount>8</burstShotCount>
        <soundCast>Shot_40mm_Autocannon</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>12</muzzleFlashScale>
        <!-- <isMortar>true</isMortar> -->
        <!-- <hasStandardCommand>true</hasStandardCommand> -->
        <requireLineOfSight>false</requireLineOfSight>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
          <canTargetPawns>true</canTargetPawns>
          <canTargetLocations>true</canTargetLocations>
          <canTargetBuildings>true</canTargetBuildings>
        </targetParams>
        <!-- <consumeFuelPerShot>1</consumeFuelPerShot> -->
      </li>
    </verbs>
  </ThingDef>
  <ThingDef ParentName="BaseWeaponTurret">
    <defName>Gun_Official_Turret</defName>
    <label>跨境执法</label>
    <description>高速穿甲武器，射速极快</description>
    <graphicData>
      <texPath>Things/Building/Security/Turret_C</texPath>
