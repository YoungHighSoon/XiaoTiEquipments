  <ThingDef ParentName="BaseWeaponTurret" MayRequire="fxz.moelotlzombie.update">
    <defName>Hand_Gun_turret_malevolent</defName>
    <label>手炮-辟邪</label>
    <description>精度较差的小型爆炸物弹射器</description>
    <graphicData>
      <texPath>Things/Weapons/Senator</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.70</drawSize>
    </graphicData>
    <soundInteract>RNPickup_R4Senator</soundInteract>
    <statBases>
      <AccuracyTouch>0.8</AccuracyTouch>
      <AccuracyShort>0.8</AccuracyShort>
      <AccuracyMedium>0.7</AccuracyMedium>
      <AccuracyLong>0.6</AccuracyLong>
      <WorkToMake>1000</WorkToMake>
      <RangedWeapon_DamageMultiplier>0.75</RangedWeapon_DamageMultiplier>
      <Mass>0.06</Mass>
      <RangedWeapon_Cooldown>2</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>XiaoTiEquipment.Verb_ShootWearableTurret</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>125_rifle_Bullet_malevolent</defaultProjectile>
        <forcedMissRadius>0.01</forcedMissRadius>
        <warmupTime>1</warmupTime>
        <range>36</range>
        <ticksBetweenBurstShots>16</ticksBetweenBurstShots>
        <burstShotCount>3</burstShotCount>
        <soundCast>P4PeaceKeeper_Shot</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
      </li>
    </verbs>
    <modExtensions MayRequire="fxz.moelotlzombie.update">
      <li Class="RigorMortis.ModExtension_TaoistArtifact">
        <level>0</level>              <!-- 需要修炼等级 -->
        <energyCost>0</energyCost>     <!-- Lotl Qi消耗 -->
        <malevolentDamage>8000</malevolentDamage>  <!-- 煞气削减 -->
        <damageCount>2</damageCount>   <!-- 附加伤害次数 -->
        <damage>0</damage>            <!-- 单次阳火伤害 -->
        <killCountRequire>50</killCountRequire>  <!-- 邪修击杀要求 -->
      </li>
    </modExtensions>
  </ThingDef>

