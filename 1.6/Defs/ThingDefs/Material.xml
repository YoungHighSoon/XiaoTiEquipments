		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<!-- <fixedIngredientFilter>
			<thingDefs>
				<li>GodGolen_Ingot</li>
			</thingDefs>
		</fixedIngredientFilter> -->
		<products>
			<GodGolen_Ingot>20</GodGolen_Ingot>
		</products>
	</RecipeDef>
