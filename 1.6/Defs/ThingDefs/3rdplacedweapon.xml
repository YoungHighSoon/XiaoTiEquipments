    <ThingDef ParentName="XiaoTiRangedWeaponBase">
		<defName>MG43_Machinegun</defName>
		<label>MG-43 通用机枪</label>
		<description>MG-43 机枪是世界上第一款通用机枪，由弹链供弹的支援武器，穿甲能力适中。它最适合固定使用，能够以持续火力压制敌方集群。</description>
		<graphicData>
			<texPath>Things/Weapons/Support/HD2_MG</texPath>
			<drawSize>1.10</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<soundInteract>Interact_Rifle</soundInteract>
		<recipeMaker>
		<researchPrerequisite>BlowbackOperation</researchPrerequisite>
		<skillRequirements>
			<Crafting>2</Crafting>
		</skillRequirements>
		</recipeMaker>
		<!-- <thingCategories>
		<li>XiaoTiApparel_Weaopn</li>
		</thingCategories> -->
