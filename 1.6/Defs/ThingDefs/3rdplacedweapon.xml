			<Mass>2</Mass>
			<Flammability>0</Flammability>
			<Beauty>6.6</Beauty>
			<RangedWeapon_Cooldown>0</RangedWeapon_Cooldown>
		</statBases>
		<costList>
			<Steel>40</Steel>
			<!-- <ComponentIndustrial>2</ComponentIndustrial> -->
		</costList>
		<equippedAngleOffset>40</equippedAngleOffset>
