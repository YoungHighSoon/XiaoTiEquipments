	<ThingDef ParentName="XiaoTiRangedWeaponBase">
		<defName>XiaoTi_AC8_Autocannon</defName>
		<label>AC-8 机炮</label>
		<description>AC-8 机炮是一款全自动加农炮，发射穿甲高爆曳光弹。这些特殊弹药能够对装甲目标造成毁灭性的穿透力，并在命中时造成爆炸。凭借其高精准度和毁灭性的火力，AC-8是绝地潜兵对抗重装敌人的顶级选择。过于轮椅的强度令大部分老玩家为了保持难度而不愿意携带。</description>
		<tickerType>Normal</tickerType>

		<equippedAngleOffset>40</equippedAngleOffset>

		<graphicData>
			<texPath>Things/Weapons/Support/HD2_Autocannon</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1.10</drawSize>
		</graphicData>
		<statBases>
      	<!-- <MaxHitPoints>1000</MaxHitPoints> -->
			<!-- <MarketValue>1800</MarketValue> -->
