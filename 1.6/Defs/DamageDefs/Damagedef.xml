<?xml version="1.0" encoding="utf-8"?><Defs>
    
    <DamageDef Name="AC8BOMB">
    <defName>AC8_BOMB</defName>
    <label>bomb</label>
    <workerClass>DamageWorker_AddInjury</workerClass>
    <externalViolence>true</externalViolence>
    <isExplosive>true</isExplosive>
    <deathMessage>{0} has died in an explosion.</deathMessage>
    <!-- <hediff>Shredded</hediff> -->
    <hediff>Stab</hediff>
    <hediffSolid>Crack</hediffSolid>
    <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
    <impactSoundType>Blunt</impactSoundType>
    <armorCategory>Sharp</armorCategory>
    <minDamageToFragment>15</minDamageToFragment>
    <defaultDamage>90</defaultDamage>
    <defaultStoppingPower>5</defaultStoppingPower>
    <defaultArmorPenetration>1.0</defaultArmorPenetration>
    <!-- <buildingDamageFactor>0.8</buildingDamageFactor> -->
    <plantDamageFactor>0.5</plantDamageFactor>
    <explosionAffectOutsidePartsOnly>false</explosionAffectOutsidePartsOnly>
    <!-- <explosionHeatEnergyPerCell>5</explosionHeatEnergyPerCell> -->
    <explosionCellFleck>BlastDry</explosionCellFleck>
    <explosionColorCenter>(255, 229, 130)</explosionColorCenter>
    <explosionColorEdge>(254, 247, 218)</explosionColorEdge>
    <soundExplosion>AC8_Explode</soundExplosion>
    <combatLogRules>Damage_Bomb</combatLogRules>
    <!-- <expolosionPropagationSpeed>0.6</expolosionPropagationSpeed> -->
  </DamageDef>

  <DamageDef Name="CutBase">
    <defName>Demolish_Cut</defName>
    <label>破墙斩</label>
    <workerClass>DamageWorker_Cut</workerClass>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} has been cut to death.</deathMessage>
    <hediff>Cut</hediff>
    <hediffSkin>Cut</hediffSkin>
    <hediffSolid>Crack</hediffSolid>
    <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
    <buildingDamageFactor>100</buildingDamageFactor>
    <buildingDamageFactorImpassable>0.75</buildingDamageFactorImpassable>
    <impactSoundType>Slice</impactSoundType>
    <armorCategory>Sharp</armorCategory>
    <overkillPctToDestroyPart>0~0.1</overkillPctToDestroyPart>
    <cutExtraTargetsCurve>
      <points>
        <li>0, 0</li>
        <li>0.6, 1</li>
        <li>0.9, 2</li>
        <li>1, 3</li>
      </points>
    </cutExtraTargetsCurve>
    <cutCleaveBonus>1.4</cutCleaveBonus>
  </DamageDef>

